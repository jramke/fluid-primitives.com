{
    "name": "typo3/cms-base-distribution",
    "description": "TYPO3 CMS Base Distribution",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "mago lint",
        "lint:fix": "mago lint --fix --format-after-fix",
        "format": "mago format",
        "format:stdin": "mago format --stdin-input",
        "analyze": "mago analyze",
        "test": "pest -c packages/fluid-primitives/phpunit.xml --test-directory=packages/fluid-primitives/tests"
    },
    "require": {
        "brainworxx/includekrexx": "^6",
        "fluid-primitives/docs": "@dev",
        "jramke/fluid-primitives": "@dev",
        "league/commonmark": "^2.7",
        "phiki/phiki": "^2.0",
        "praetorius/vite-asset-collector": "^1",
        "symfony/yaml": "^7.3",
        "typo3/cms-backend": "^14.1",
        "typo3/cms-belog": "^14.1",
        "typo3/cms-beuser": "^14.1",
        "typo3/cms-core": "^14.1",
        "typo3/cms-extbase": "^14.1",
        "typo3/cms-extensionmanager": "^14.1",
        "typo3/cms-filelist": "^14.1",
        "typo3/cms-fluid": "^14.1",
        "typo3/cms-fluid-styled-content": "^14.1",
        "typo3/cms-frontend": "^14.1",
        "typo3/cms-impexp": "^14.1",
        "typo3/cms-info": "^14.1",
        "typo3/cms-install": "^14.1",
        "typo3/cms-lowlevel": "^14.1",
        "typo3/cms-seo": "^14.1",
        "typo3/cms-setup": "^14.1",
        "typo3/cms-sys-note": "^14.1",
        "typo3/cms-tstemplate": "^14.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*"
        }
    ],
    "require-dev": {
        "carthage-software/mago": "^1.15",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.4",
        "typo3/testing-framework": "^9.4"
    },
    "autoload-dev": {
        "psr-4": {
            "Jramke\\FluidPrimitives\\Tests\\": "packages/fluid-primitives/tests"
        }
    }
}
